# Supabase project (Project Settings → API)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
# Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=replace-me

# Postgres connection string (Project Settings → Database → Connection string → URI)
# Use the pooler (port 6543) for runtime, direct (5432) for Alembic.
DATABASE_URL=postgresql+psycopg://postgres:password@db.xxxxx.supabase.co:5432/postgres

# CORS — comma-separated origins of the Vite dev server / web app
CORS_ORIGINS=http://localhost:5173

# Listen
PORT=8000
